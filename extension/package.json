{
  "name": "docs-browser-extension",
  "displayName": "Docs Browser",
  "version": "0.2.0",
  "private": true,
  "description": "Serve generated docs in a real-DOM webview pane, with a co-located Playwright engine and a hosted MCP server for AI-driven doc development & testing.",
  "publisher": "local",
  "engines": {
    "vscode": "^1.101.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "docsBrowser", "title": "Docs Browser", "icon": "media/docs.svg" }
      ]
    },
    "views": {
      "docsBrowser": [
        { "id": "docsBrowser.pages", "name": "Documentation" }
      ]
    },
    "viewsWelcome": [
      { "view": "docsBrowser.pages", "contents": "Open a folder with generated HTML docs, then launch the browser.\n[Open Docs Browser](command:docsBrowser.open)" }
    ],
    "commands": [
      { "command": "docsBrowser.open", "title": "Open", "category": "Docs Browser", "icon": "$(open-preview)" },
      { "command": "docsBrowser.refresh", "title": "Refresh", "category": "Docs Browser", "icon": "$(refresh)" }
    ],
    "menus": {
      "view/title": [
        { "command": "docsBrowser.open", "when": "view == docsBrowser.pages", "group": "navigation@1" },
        { "command": "docsBrowser.refresh", "when": "view == docsBrowser.pages", "group": "navigation@2" }
      ]
    },
    "configuration": {
      "title": "Docs Browser",
      "properties": {
        "docsBrowser.docsDir": {
          "type": "string",
          "default": "docs",
          "description": "Directory (relative to the workspace, or absolute) of generated HTML docs to serve."
        },
        "docsBrowser.mcpPort": {
          "type": "number",
          "default": 8765,
          "description": "Fixed port for the hosted MCP HTTP server (referenced by .mcp.json). On conflict the extension fails loudly rather than picking another port."
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "package": "vsce package --no-dependencies --allow-missing-repository -o docs-browser-extension.vsix"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright-core": "^1.61.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.101.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
