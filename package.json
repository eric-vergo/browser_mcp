{
  "name": "browser-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "View auto-generated docs in VSCode's Simple Browser, driven by an MCP server (screenshot + navigation for Claude).",
  "workspaces": [
    "mcp-server",
    "extension"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:mcp": "npm -w mcp-server run build",
    "build:ext": "npm -w extension run build",
    "postinstall": "playwright install chromium",
    "install:ext": "bash scripts/install-extension.sh",
    "package:ext": "npm -w extension run package"
  }
}
